# ─── API de Gemini ───
# Consigue tu key gratis en: https://aistudio.google.com/app/apikey
# En Vercel, agrégala en: Project Settings → Environment Variables

GEMINI_API_KEY=tu_api_key_aqui

# (Opcional) Keys extra para rotación automática si una se satura.
# El servidor las prueba en orden hasta que una funcione.
# GEMINI_API_KEY_2=
# GEMINI_API_KEY_3=
# GEMINI_API_KEY_4=
